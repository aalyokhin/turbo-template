{
  "name": "turbo-template",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "oxlint --type-aware -c oxlint.json",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    "db:migrate": "DATABASE_URL=file:$PWD/apps/api/app.db pnpm --filter @repo/db run db:migrate",
    "db:studio": "DATABASE_URL=file:$PWD/apps/api/app.db pnpm --filter @repo/db run db:studio",
    "setup": "node scripts/setup.mjs",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check && pnpm test"
  },
  "devDependencies": {
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0"
}
