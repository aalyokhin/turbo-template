{
  "name": "@repo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/src/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@libsql/client": "^0.17.3",
    "@orpc/server": "^1.13.0",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "4.1.8",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
